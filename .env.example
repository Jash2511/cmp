# =================================
# DATABASE (Supabase)
# =================================
# Get this from your Supabase project: Settings -> Database -> Connection string -> URI
SUPABASE_URL="postgresql://postgres:[YOUR-PASSWORD]@db.xxxx.supabase.co:5432/postgres"

# =================================
# AI (Groq)
# =================================
# Get this from your GroqCloud dashboard: https://console.groq.com/keys
GROQ_API_KEY="gsk_your_groq_api_key_here"

# =================================
# EMAIL CONFIGURATION (SMTP)
# =================================
# The address of your email provider's SMTP server
SMTP_SERVER="smtp.gmail.com"

# The port for the SMTP server (usually 587 for TLS)
SMTP_PORT="587"

# Your email address (the username for the SMTP server)
SMTP_USER="your_email@gmail.com"

# Your email password or an app-specific password (Recommended: App Password)
SMTP_PASSWORD="your_16_character_app_password"

# The email address that will appear in the "From" field
SENDER_EMAIL="your_email@gmail.com"

# =================================
# REDIS CONFIGURATION
# =================================
# Hostname or IP address of your Redis server (default: localhost)
REDIS_HOST="localhost"

# Port number for your Redis server (default: 6379)
REDIS_PORT="6379"

# Password for your Redis server, if applicable (leave empty if none)
REDIS_PASSWORD="your_redis_default_password"

# Name of the queue used for moderation tasks (default: moderation_queue)
QUEUE_NAME="moderation_queue"